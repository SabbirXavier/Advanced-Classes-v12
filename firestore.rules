rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    function isAuthenticated() {
      return request.auth != null;
    }

    function isSignedIn() {
      return isAuthenticated();
    }

    function userDoc() {
      return get(/databases/$(database)/documents/users/$(request.auth.uid)).data;
    }

    function roleFromClaims() {
      return isAuthenticated() && request.auth.token.role is string ? request.auth.token.role : null;
    }

    function roleFromUserDoc() {
      return isAuthenticated() && exists(/databases/$(database)/documents/users/$(request.auth.uid)) && userDoc().role is string
        ? userDoc().role
        : null;
    }

    function hasRole(role) {
      return isAuthenticated() && (
        roleFromClaims() == role ||
        roleFromUserDoc() == role ||
        (exists(/databases/$(database)/documents/users/$(request.auth.uid)) && userDoc().roles is list && role in userDoc().roles)
      );
    }

    function isAdmin() { return hasRole('admin'); }
    function isFaculty() { return hasRole('faculty'); }
    function isStudent() { return hasRole('student'); }

    function isSelf(uid) {
      return isAuthenticated() && request.auth.uid == uid;
    }

    function facultyHasAssignment(subject, batchId) {
      return isFaculty() && (
        (request.auth.token.assigned_subjects is list && subject in request.auth.token.assigned_subjects) ||
        exists(/databases/$(database)/documents/batchFaculty/$(request.auth.uid + '_' + batchId + '_' + subject)) ||
        exists(/databases/$(database)/documents/batchFaculty/$(request.auth.uid + '_' + batchId + '_ALL'))
      );
    }

    // ============================
    // STEP 1 Requested collections
    // ============================

    // Users (role-aware)
    match /users/{userId} {
      allow read: if isAdmin() || isSelf(userId);
      allow create: if isSelf(userId) || isAdmin();
      allow update: if isAdmin() || (isSelf(userId) && request.resource.data.role == resource.data.role);
      allow delete: if isAdmin();
    }

    // Immutable monthly ledger snapshots
    match /student_fee_ledger_v2/{ledgerId} {
      allow read: if isAdmin()
        || (isFaculty() && (
          (resource.data.assigned_faculty_ids is list && request.auth.uid in resource.data.assigned_faculty_ids)
          || (request.auth.token.assigned_student_ids is list && resource.data.student_id in request.auth.token.assigned_student_ids)
        ))
        || (isStudent() && resource.data.student_id == request.auth.uid);

      // Financial immutability: no updates/deletes from clients.
      allow create: if isAdmin();
      allow update, delete: if false;
    }

    // Immutable payment records V2, backend/admin only writes.
    match /fee_payments_v2/{paymentId} {
      allow read: if isAdmin()
        || (isFaculty() && (
          (resource.data.assigned_faculty_ids is list && request.auth.uid in resource.data.assigned_faculty_ids)
          || (request.auth.token.assigned_student_ids is list && resource.data.student_id in request.auth.token.assigned_student_ids)
        ))
        || (isStudent() && resource.data.student_id == request.auth.uid);
      allow create: if isAdmin();
      allow update, delete: if false;
    }

    // Attendance records (faculty limited writes)
    match /attendance_records/{recordId} {
      allow read: if isAdmin()
        || (isFaculty() && resource.data.faculty_id == request.auth.uid)
        || (isStudent() && resource.data.student_id == request.auth.uid);

      allow create: if isAdmin() || (
        isFaculty()
        && request.resource.data.faculty_id == request.auth.uid
        && request.resource.data.subject is string
        && request.resource.data.batch_id is string
        && facultyHasAssignment(request.resource.data.subject, request.resource.data.batch_id)
      );

      // Immutable edit trail pattern: clients create revised docs, not updates.
      allow update, delete: if isAdmin();
    }

    // Earnings snapshots (immutable by client)
    match /faculty_earnings_v2/{earningId} {
      allow read: if isAdmin() || (isFaculty() && resource.data.faculty_id == request.auth.uid);
      allow create: if isAdmin();
      allow update, delete: if false;
    }

    // ============================
    // Backward-compatible existing collections
    // ============================

    match /enrollments/{id} {
      allow read: if true;
      allow create: if isAuthenticated();
      allow update: if isAdmin() || (isAuthenticated() && resource.data.email == request.auth.token.email);
      allow delete: if isAdmin();
    }

    match /batches/{id} { allow read: if true; allow write: if isAdmin(); }
    match /routines/{id} { allow read: if true; allow write: if isAdmin(); }
    match /fees/{id} { allow read: if true; allow write: if isAdmin(); }
    match /pricing_plans/{id} { allow read: if true; allow write: if isAdmin(); }
    match /pricing_rules/{id} { allow read: if true; allow write: if isAdmin(); }
    match /downloads/{id} { allow read: if true; allow write: if isAdmin(); }
    match /radars/{id} { allow read: if true; allow write: if isAdmin(); }
    match /teasers/{id} { allow read: if true; allow write: if isAdmin(); }
    match /drops/{id} { allow read: if true; allow write: if isAdmin(); }
    match /stars/{id} { allow read: if true; allow write: if isAdmin(); }
    match /channels_config/{id} { allow read: if true; allow write: if isAdmin(); }
    match /channels/{channelId}/messages/{id} { allow read: if isAuthenticated(); allow write: if isAuthenticated(); }
    match /batchFaculty/{id} { allow read: if true; allow write: if isAdmin(); }
    match /faculty_attendance/{id} {
      allow read: if isAuthenticated();
      allow create: if isAdmin() || (isFaculty() && request.resource.data.userId == request.auth.uid);
      allow update, delete: if isAdmin() || (isFaculty() && resource.data.userId == request.auth.uid);
    }
    match /payouts/{id} { allow read: if isAdmin() || (isSignedIn() && resource.data.userId == request.auth.uid); allow write: if isAdmin(); }
    match /finance_ledger/{id} { allow read, write: if isAdmin(); }
    match /payout_requests/{id} {
      allow read: if isAdmin() || (isSignedIn() && resource.data.userId == request.auth.uid);
      allow create: if isFaculty() && request.resource.data.userId == request.auth.uid;
      allow update, delete: if isAdmin() || (isFaculty() && resource.data.userId == request.auth.uid);
    }
    match /faculty_salaries/{id} { allow read: if isAdmin() || (isSignedIn() && resource.data.userId == request.auth.uid); allow write: if isAdmin(); }
    match /resignations/{id} {
      allow read: if isAdmin() || (isSignedIn() && resource.data.userId == request.auth.uid);
      allow create: if isFaculty() && request.resource.data.userId == request.auth.uid;
      allow update, delete: if isAdmin() || (isFaculty() && resource.data.userId == request.auth.uid);
    }
    match /reminder_logs/{id} { allow read, write: if isAdmin(); }
    match /audit_logs/{id} { allow read, write: if isAdmin(); }
    match /activity/{id} { allow read: if isAuthenticated(); allow write: if isAdmin(); }
    match /_health/{id} { allow read: if true; }

    // Default deny (production-safe)
    match /{document=**} {
      allow read, write: if false;
    }
  }
}
